<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="700.0" prefWidth="1100.0" spacing="20.0" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.movielibrary.controller.RegisterController">
    <children>

        <Label styleClass="label-title" text="ĐĂNG KÝ TÀI KHOẢN" />

        <VBox maxWidth="350.0" spacing="15.0">
            <children>
                <VBox spacing="5.0">
                    <children>
                        <Label styleClass="label-info" text="Tên đăng nhập (Ít nhất 4 ký tự):" />
                        <TextField fx:id="txtUsername" promptText="Nhập tên đăng nhập..." />
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label styleClass="label-info" text="Mật khẩu:" />
                        <PasswordField fx:id="txtPassword" promptText="Nhập mật khẩu..." />
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label styleClass="label-info" text="Xác nhận mật khẩu:" />
                        <PasswordField fx:id="txtConfirmPassword" promptText="Nhập lại mật khẩu..." />
                    </children>
                </VBox>

                <Button fx:id="btnRegister" defaultButton="true" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleRegister" text="Đăng Ký Tài Khoản">
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </Button>

                <VBox alignment="CENTER" spacing="10.0">
                    <children>
                        <Button fx:id="btnBack" mnemonicParsing="false" onAction="#handleBackToLogin" styleClass="btn-secondary" text="Quay lại Đăng nhập" />
                    </children>
                    <VBox.margin>
                        <Insets top="15.0" />
                    </VBox.margin>
                </VBox>
            </children>
        </VBox>

    </children>
</VBox>