<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<BorderPane fx:id="borderPane" prefHeight="700.0" prefWidth="1100.0" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.movielibrary.controller.MainLayoutController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="60.0" styleClass="header-bar" BorderPane.alignment="CENTER">
            <children>
                <Label styleClass="header-title" text="THƯ VIỆN ĐIỆN ẢNH" />

                <Region HBox.hgrow="ALWAYS" />

                <Label fx:id="lblWelcome" styleClass="header-welcome" text="Xin chào, Khách!">
                    <HBox.margin>
                        <Insets right="20.0" />
                    </HBox.margin>
                </Label>

                <Button fx:id="btnAuth" mnemonicParsing="false" onAction="#handleAuthAction" text="Đăng nhập / Đăng xuất" />
            </children>
        </HBox>
    </top>

    <center>
    </center>

</BorderPane>