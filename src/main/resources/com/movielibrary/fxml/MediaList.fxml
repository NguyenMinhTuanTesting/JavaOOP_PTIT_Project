<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="640.0" prefWidth="1100.0" spacing="15.0" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.movielibrary.controller.MediaListController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>

        <HBox alignment="CENTER_LEFT" spacing="15.0">
            <children>
                <TextField fx:id="txtSearch" onAction="#handleSearchAndFilter" prefWidth="250.0" promptText="Nhập tên phim cần tìm..." />
                <Button mnemonicParsing="false" onAction="#handleSearchAndFilter" text="Tìm kiếm" />

                <Region HBox.hgrow="ALWAYS" />

                <Label styleClass="label-info" text="Thể loại:" />
                <ComboBox fx:id="cbFilterGenre" prefWidth="150.0" />

                <Label styleClass="label-info" text="Sắp xếp:">
                    <HBox.margin>
                        <Insets left="15.0" />
                    </HBox.margin>
                </Label>
                <ComboBox fx:id="cbSort" prefWidth="150.0" />
            </children>
        </HBox>

        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #0d1117;" VBox.vgrow="ALWAYS">
            <content>
                <FlowPane fx:id="mediaContainer" hgap="20.0" vgap="20.0">
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                    </padding>
                </FlowPane>
            </content>
        </ScrollPane>

        <HBox alignment="CENTER" spacing="20.0">
            <children>
                <Button fx:id="btnPrevPage" mnemonicParsing="false" onAction="#handlePrevPage" styleClass="btn-secondary" text="&lt; Trang Trước" />
                <Label fx:id="lblPageInfo" style="-fx-text-fill: white; -fx-font-weight: bold;" text="Trang 1 / 1" />
                <Button fx:id="btnNextPage" mnemonicParsing="false" onAction="#handleNextPage" styleClass="btn-secondary" text="Trang Tiếp &gt;" />
            </children>
        </HBox>
    </children>
</VBox>