<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" prefHeight="640.0" prefWidth="1100.0" style="-fx-background: #0d1117; -fx-background-color: transparent;" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.movielibrary.controller.MediaDetailController">
    <content>
        <VBox spacing="25.0">
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="20.0" />
            </padding>
            <children>

                <Button mnemonicParsing="false" onAction="#handleBack" styleClass="btn-secondary" text="&lt; Quay lại danh sách" />

                <HBox spacing="30.0">
                    <children>

                        <VBox alignment="TOP_CENTER" spacing="15.0">
                            <children>
                                <ImageView fx:id="imgPoster" fitHeight="400.0" fitWidth="280.0" pickOnBounds="true" preserveRatio="false" style="-fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.8), 15, 0, 0, 5);" />
                                <VBox alignment="CENTER" style="-fx-background-color: #161b22; -fx-padding: 15; -fx-background-radius: 8; -fx-border-color: #30363d; -fx-border-radius: 8;">
                                    <children>
                                        <Label styleClass="label-info" text="Điểm đánh giá trung bình:" />
                                        <Label fx:id="lblRating" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #ffc107;" text="0.0 / 10" />
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label fx:id="lblTitle" styleClass="label-title" text="Tên Phim Sẽ Hiển Thị Ở Đây" wrapText="true" />

                                <HBox alignment="CENTER_LEFT" spacing="15.0">
                                    <children>
                                        <FlowPane fx:id="paneType" alignment="CENTER_LEFT" />
                                        <FlowPane fx:id="paneYear" alignment="CENTER_LEFT" />
                                        <Label text="•" textFill="#8b949e" />
                                        <Label fx:id="lblDuration" styleClass="label-info" text="120 Phút" />
                                    </children>
                                </HBox>

                                <FlowPane fx:id="genreTagsPane" hgap="10.0" vgap="10.0">
                                    <VBox.margin>
                                        <Insets bottom="10.0" top="5.0" />
                                    </VBox.margin>
                                </FlowPane>

                                <HBox spacing="10.0">
                                    <Label styleClass="label-info" text="Quốc gia:" />
                                    <FlowPane fx:id="paneCountry" hgap="5.0" vgap="5.0" />
                                </HBox>
                                <HBox spacing="10.0">
                                    <Label styleClass="label-info" text="Đạo diễn:" />
                                    <FlowPane fx:id="paneDirector" hgap="5.0" vgap="5.0" />
                                </HBox>
                                <HBox spacing="10.0">
                                    <Label styleClass="label-info" text="Diễn viên:" />
                                    <FlowPane fx:id="paneCast" hgap="5.0" vgap="5.0" />
                                </HBox>

                                <Label style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px;" text="Nội dung phim:">
                                    <VBox.margin>
                                        <Insets top="15.0" />
                                    </VBox.margin>
                                </Label>
                                <Label fx:id="lblDescription" style="-fx-text-fill: #c9d1d9; -fx-line-spacing: 5px;" text="Nội dung mô tả sẽ được nạp ở đây..." wrapText="true" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <Region style="-fx-background-color: #30363d;" VBox.vgrow="NEVER">
                    <padding>
                        <Insets top="2.0" />
                    </padding>
                    <VBox.margin>
                        <Insets bottom="10.0" top="10.0" />
                    </VBox.margin>
                </Region>

                <Label styleClass="label-title" text="Đánh giá &amp; Bình luận" />

                <VBox fx:id="reviewFormContainer" spacing="15.0" style="-fx-background-color: #161b22; -fx-padding: 20; -fx-background-radius: 8; -fx-border-color: #007bff; -fx-border-radius: 8;">
                    <children>
                        <Label style="-fx-text-fill: #58a6ff; -fx-font-weight: bold;" text="Thêm đánh giá của bạn" />

                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                            <children>
                                <Label styleClass="label-info" text="Chấm điểm:" />
                                <Slider fx:id="sliderRating" blockIncrement="0.5" majorTickUnit="1.0" max="10.0" min="1.0" minorTickCount="1" prefWidth="300.0" showTickLabels="true" showTickMarks="true" snapToTicks="true" value="10.0" />
                                <Label fx:id="lblRatingValue" style="-fx-font-weight: bold; -fx-text-fill: white;" text="10.0 / 10.0" />
                            </children>
                        </HBox>

                        <TextArea fx:id="txtComment" prefHeight="80.0" promptText="Viết bình luận của bạn về phim này (không bắt buộc, tối đa 1000 ký tự)..." wrapText="true" />

                        <Button fx:id="btnSubmitReview" mnemonicParsing="false" onAction="#handleSubmitReview" text="Gửi Đánh Giá" />
                    </children>
                </VBox>

                <VBox fx:id="reviewListContainer" spacing="15.0" />

            </children>
        </VBox>
    </content>
</ScrollPane>